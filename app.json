{
  "expo": {
    "name": "SweetSpot",
    "slug": "torneosdetenis",
    "version": "3.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "torneosdetenis",
    "splash": {
      "image": "./assets/LogoSweetSpot.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pitin.torneosdetenis",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a la galeria para elegir imagenes de perfil y organizacion.",
        "NSUserNotificationsUsageDescription": "Usamos notificaciones para avisarte de cambios en torneos y partidos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.pitin.torneosdetenis",
      "versionCode": 5,
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Permite usar Face ID para proteger tu sesion."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tu galeria para seleccionar imagenes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/LogoSweetSpot.png",
          "color": "#0f172a"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74e9c55f-97e5-47f7-894c-54286eef00f9"
      }
    }
  }
}
