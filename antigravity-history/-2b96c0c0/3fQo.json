{
    "cli": {
        "version": ">= 12.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": false
            },
            "env": {
                "npm_config_legacy_peer_deps": "true"
            }
        },
        "production": {
            "autoIncrement": true
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "your-apple-id@email.com",
                "ascAppId": "your-app-store-connect-app-id"
            },
            "android": {
                "serviceAccountKeyPath": "./pc-api-key.json"
            }
        }
    }
}